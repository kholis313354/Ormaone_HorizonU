<IfModule mod_rewrite.c>
    RewriteEngine On

    # ✅ ALLOW DIRECT ACCESS TO UPLOADS FOLDER (untuk QR code, images, files)
    # Skip routing jika file benar-benar ada di folder uploads
    # Prioritaskan akses langsung ke file di uploads (termasuk qrcode)
    RewriteCond %{REQUEST_URI} ^/uploads/
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]
    
    # ✅ KHUSUS UNTUK QR CODE (memastikan file PNG bisa diakses)
    RewriteCond %{REQUEST_URI} ^/uploads/qrcode/.*\.(png|jpg|jpeg|gif)$ [NC]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]

    # 🎯 ROUTING UTAMA UNTUK CODEIGNITER/LARAVEL
    # Skip routing untuk file yang benar-benar ada (termasuk uploads)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php/$1 [L]

    # ✅ KHUSUS VERIFIKASI
    RewriteRule ^verifikasi/([0-9]+)$ index.php/sertifikat/verifikasi/$1 [L]
</IfModule>

# 🔒 BLOKIR FILE SENSITIF
<FilesMatch "^(\.env|\.htaccess|composer\.(json|lock)|\.git|phpunit\.xml)$">
    Require all denied
</FilesMatch>

# 🌐 CORS UNTUK FONT, SCRIPT, DAN GAMBAR (termasuk QR Code)
<IfModule mod_headers.c>
    <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|css|js|png|jpg|jpeg|gif|webp|svg)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

# 📛 NONAKTIFKAN DIRECTORY LISTING
Options -Indexes

# ✅ IZINKAN AKSES KE FILE GAMBAR DI UPLOADS/QRCODE
<DirectoryMatch "^.*/uploads/qrcode">
    Options -Indexes
    <FilesMatch "\.(png|jpg|jpeg|gif|webp)$">
        Require all granted
    </FilesMatch>
</DirectoryMatch>